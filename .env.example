# Copy to .env for local development. Never commit .env.
TASKFLOW_ENVIRONMENT=dev
TASKFLOW_DATABASE_URL=postgresql+psycopg://taskflow:taskflow@localhost:5432/taskflow
TASKFLOW_JWT_SECRET=change-me-to-a-long-random-string
TASKFLOW_ACCESS_TOKEN_TTL_MINUTES=15
TASKFLOW_REFRESH_TOKEN_TTL_DAYS=7
TASKFLOW_RATE_LIMIT_ENABLED=true
TASKFLOW_RATE_LIMIT_PER_MINUTE=120
TASKFLOW_RATE_LIMIT_BURST=40
