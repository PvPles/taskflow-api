# Copy to .env for local development. Never commit .env.
# Every variable the app reads (see app/core/config.py). All have defaults;
# in production you MUST override TASKFLOW_JWT_SECRET and TASKFLOW_DATABASE_URL.
TASKFLOW_ENVIRONMENT=dev
TASKFLOW_DATABASE_URL=postgresql+psycopg://taskflow:taskflow@localhost:5432/taskflow

# Auth. JWT secret must be >= 32 bytes for HS256.
TASKFLOW_JWT_SECRET=change-me-to-a-long-random-string
TASKFLOW_JWT_ALGORITHM=HS256
TASKFLOW_ACCESS_TOKEN_TTL_MINUTES=15
TASKFLOW_REFRESH_TOKEN_TTL_DAYS=7

# Per-user rate limiting (token bucket).
TASKFLOW_RATE_LIMIT_ENABLED=true
TASKFLOW_RATE_LIMIT_PER_MINUTE=120
TASKFLOW_RATE_LIMIT_BURST=40

# Cosmetic - shown as the OpenAPI title.
TASKFLOW_APP_NAME=TaskFlow API
