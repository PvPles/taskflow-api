# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

aws_region = "eu-central-1"
app_image  = "ghcr.io/YOUR_GITHUB/taskflow-api:latest"

# Optional - HTTPS via ACM (requires a domain in Route53):
# domain_name     = "api.example.com"
# route53_zone_id = "Z0123456789ABC"

# Optional - SSH access for debugging:
# ssh_key_name     = "my-keypair"
# ssh_allowed_cidr = "203.0.113.7/32"
