# Remote state (optional, recommended once this is more than a demo).
#
# One-time bootstrap in your account:
#   aws s3 mb s3://YOUR-tf-state-bucket --region eu-central-1
#   aws s3api put-bucket-versioning --bucket YOUR-tf-state-bucket \
#     --versioning-configuration Status=Enabled
#   aws dynamodb create-table --table-name terraform-locks \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST
#
# Then add `backend "s3" {}` inside the terraform block in versions.tf,
# copy this file to backend.hcl, and run:  terraform init -backend-config=backend.hcl

bucket         = "YOUR-tf-state-bucket"
key            = "taskflow/terraform.tfstate"
region         = "eu-central-1"
dynamodb_table = "terraform-locks"
encrypt        = true
